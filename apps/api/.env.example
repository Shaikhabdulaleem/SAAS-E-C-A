# ── Required ─────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/nexushq?schema=public"
JWT_ACCESS_SECRET="replace-with-a-strong-access-secret"
JWT_REFRESH_SECRET="replace-with-a-strong-refresh-secret"
ENCRYPTION_KEY="replace-with-32-byte-encryption-key"
CORS_ORIGINS="http://localhost:5173"
NODE_ENV="development"
PORT="3001"

# ── Optional — direct DB URL for migrations (bypasses pooler) ──
# DIRECT_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/nexushq?schema=public"

# ── Redis (required for workers, optional for API) ───────
REDIS_URL="redis://localhost:6379"

# ── Email Delivery ───────────────────────────────────────
# SENDGRID_API_KEY=""
# SENDGRID_WEBHOOK_PUBLIC_KEY=""
# SYSTEM_FROM_EMAIL="noreply@nexushq.io"
# SYSTEM_FROM_NAME="NexusHQ"

# ── Stripe Billing ───────────────────────────────────────
# STRIPE_SECRET_KEY=""
# STRIPE_WEBHOOK_SECRET=""

# ── Google OAuth (for workspace provisioning) ────────────
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
# GOOGLE_REDIRECT_URI="http://localhost:3001/api/provisioning/google/callback"

# ── AI ───────────────────────────────────────────────────
# OPENAI_API_KEY=""
# OPENAI_SUMMARY_MODEL="gpt-4.1-mini"

# ── Error Tracking ───────────────────────────────────────
# SENTRY_DSN=""
# APP_VERSION="1.0.0"

# ── Rate Limiting ────────────────────────────────────────
# RATE_LIMIT_WINDOW_MS="60000"
# RATE_LIMIT_MAX="600"
# AUTH_RATE_LIMIT_MAX="10"
# AI_RATE_LIMIT_MAX="60"

# ── Logging ──────────────────────────────────────────────
# LOG_LEVEL="info"

# ── App URLs ─────────────────────────────────────────────
# APP_PUBLIC_URL="http://localhost:5173"
VITE_API_URL="http://localhost:3001/api"

# ── Backup (for scripts/backup-db.sh) ────────────────────
# BACKUP_S3_BUCKET=""
# BACKUP_DIR="./backups"
