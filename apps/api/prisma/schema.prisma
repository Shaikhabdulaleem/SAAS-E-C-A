  @@index([tenantId, status])
  @@index([tenantId, createdAt])
}

model ColdSequenceStep {
  id              String        @id @default(uuid())
  campaignId      String
  stepOrder       Int
  subject         String?
  body            String
  delayDays       Int           @default(2)
  useThreading    Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  campaign        ColdCampaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  sequenceStates  ColdSequenceState[]

  @@unique([campaignId, stepOrder])
  @@index([campaignId])
}

model ColdCampaignMailbox {
  id         String       @id @default(uuid())
  campaignId String
  mailboxId  String
  campaign   ColdCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  mailbox    ColdMailbox  @relation(fields: [mailboxId], references: [id], onDelete: Cascade)

  @@unique([campaignId, mailboxId])
}

model ColdSequenceState {
  id              String             @id @default(uuid())
  campaignId      String
  prospectId      String
  currentStepId   String?
  status          ColdProspectStatus @default(queued)
  lastSentAt      DateTime?
  nextSendAfter   DateTime?
  completedAt     DateTime?
  campaign        ColdCampaign       @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  prospect        ColdProspect       @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  currentStep     ColdSequenceStep?  @relation(fields: [currentStepId], references: [id], onDelete: SetNull)

  @@unique([campaignId, prospectId])
  @@index([campaignId, status])
  @@index([nextSendAfter])
}

model ColdEmailEvent {
  id          String       @id @default(uuid())
  campaignId  String
  prospectId  String?
  stepOrder   Int?
  type        String
  metadata    Json?
  occurredAt  DateTime     @default(now())
  campaign    ColdCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId, type])
  @@index([campaignId, occurredAt])
}

