enum EmailFormat {
  firstname_at
  firstname_dot_lastname
  firstnamelastname
  f_dot_lastname
}

enum EmailProviderType {
  google_workspace
  microsoft_365
}

enum DnsProviderType {
  cloudflare
  namecheap
}

model Persona {
  id                String           @id @default(uuid())
  tenantId          String
  domainId          String
  mailboxId         String?          @unique
  firstName         String
  lastName          String
  email             String
  jobTitle          String?
  companyName       String?
  phone             String?
  profilePhoto      String?
  signature         String?
  warmupStatus      WarmupStatus     @default(not_started)
  warmupDay         Int              @default(0)
  healthScore       Int              @default(0)
  dailySendLimit    Int              @default(5)
  sentToday         Int              @default(0)
  totalSent         Int              @default(0)
  bounceRate        Decimal          @db.Decimal(5, 2) @default(0)
  spamRate          Decimal          @db.Decimal(5, 2) @default(0)
  linkedinConnected Boolean          @default(false)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  tenant            Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  domain            SendingDomain    @relation(fields: [domainId], references: [id], onDelete: Cascade)
  mailbox           ColdMailbox?     @relation(fields: [mailboxId], references: [id], onDelete: SetNull)
  linkedinSlot      LinkedInSlot?
  warmupLogs        WarmupLog[]      @relation("PersonaWarmupLogs")
  sendingLogs       SendingLog[]     @relation("PersonaSendingLogs")

  @@unique([tenantId, email])
  @@index([tenantId, domainId])
  @@index([tenantId, warmupStatus])
}

model LinkedInSlot {
  id                String    @id @default(uuid())
  personaId         String    @unique
  profileUrl        String?
  headline          String?
  suggestedBio      String?
  connectionLimit   Int       @default(20)
  messageLimit      Int       @default(50)
  connectionsCount  Int       @default(0)
  messagesSent      Int       @default(0)
  replyRate         Decimal   @db.Decimal(5, 2) @default(0)
  connected         Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  persona           Persona   @relation(fields: [personaId], references: [id], onDelete: Cascade)
}

model WarmupLog {
  id              String      @id @default(uuid())
  personaId       String?
  mailboxId       String?
  date            DateTime    @default(now()) @db.Date
  emailsSent      Int         @default(0)
  emailsReceived  Int         @default(0)
  repliesReceived Int         @default(0)
  spamCount       Int         @default(0)
  bounceCount     Int         @default(0)
  persona         Persona?    @relation("PersonaWarmupLogs", fields: [personaId], references: [id], onDelete: Cascade)
  mailbox         ColdMailbox? @relation(fields: [mailboxId], references: [id], onDelete: Cascade)

  @@index([personaId, date])
  @@index([mailboxId, date])
}

model SendingLog {
  id            String       @id @default(uuid())
  personaId     String?
  mailboxId     String?
  campaignId    String?
  prospectId    String?
  sentAt        DateTime     @default(now())
  status        String       @default("sent")
  openTracked   Boolean      @default(false)
  clickTracked  Boolean      @default(false)
  repliedAt     DateTime?
  bouncedAt     DateTime?
  persona       Persona?     @relation("PersonaSendingLogs", fields: [personaId], references: [id], onDelete: SetNull)
  mailbox       ColdMailbox? @relation(fields: [mailboxId], references: [id], onDelete: SetNull)

  @@index([personaId, sentAt])
  @@index([mailboxId, sentAt])
  @@index([campaignId, sentAt])
}

model DomainHealthLog {
  id              String        @id @default(uuid())
  domainId        String
  checkedAt       DateTime      @default(now())
  blacklistStatus String        @default("clean")
  spfValid        Boolean       @default(false)
  dkimValid       Boolean       @default(false)
  dmarcValid      Boolean       @default(false)
  healthScore     Int           @default(0)
  domain          SendingDomain @relation(fields: [domainId], references: [id], onDelete: Cascade)

  @@index([domainId, checkedAt])
}

model CallSession {
  id          String            @id @default(uuid())
  tenantId    String
  userId      String
  contactId   String?
  dealId      String?
  provider    String?
  providerCallId String?
  title       String
  status      CallSessionStatus @default(uploaded)
  startedAt   DateTime?
  endedAt     DateTime?
  durationSec Int?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  tenant      Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  recordings  CallRecording[]
  transcripts CallTranscript[]
  insights    CallInsight[]

  @@index([tenantId, createdAt])
  @@index([provider, providerCallId])
}

model CallRecording {
  id          String      @id @default(uuid())
  tenantId    String
  sessionId   String
  storageUrl  String
  mimeType    String?
  durationSec Int?
  uploadedAt  DateTime    @default(now())
  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  session     CallSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([tenantId, sessionId])
}

model CallTranscript {
  id          String      @id @default(uuid())
  tenantId    String
  sessionId   String
  provider    String      @default("openai")
  language    String?
  text        String
  speakerLabels Json?
  createdAt   DateTime    @default(now())
  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  session     CallSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([tenantId, sessionId])
}

model CallInsight {
  id             String      @id @default(uuid())
  tenantId        String
  sessionId       String
  summary         String
  objections      Json?
  actionItems     Json?
  sentiment       String?
  coachingScore   Int?
  followUpEmail   String?
  model           String?
  tokens          Int         @default(0)
  costEstimate    Decimal?    @db.Decimal(12, 6)
  createdAt       DateTime    @default(now())
  tenant          Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  session         CallSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([tenantId, sessionId])
}

model OnboardingItem {
  id          String   @id @default(uuid())
  tenantId    String
  key         String
  label       String
  completedAt DateTime?
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, key])
  @@index([tenantId, completedAt])
}
