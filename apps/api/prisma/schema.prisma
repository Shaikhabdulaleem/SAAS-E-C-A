  blacklistStatus      String          @default("clean")
  blacklistCheckedAt   DateTime?
  lastCheckedAt        DateTime?
  targetDailyVolume    Int?
  requiredMailboxes    Int?
  dnsProvider          DnsProviderType?
  dnsApiKeyCipher      String?
  dnsZoneId            String?
  providerCredentialId String?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  tenant               Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  providerCredential   EmailProviderCredential? @relation(fields: [providerCredentialId], references: [id], onDelete: SetNull)
  mailboxes            ColdMailbox[]
  personas             Persona[]
  healthLogs           DomainHealthLog[]

  @@unique([tenantId, domain])
  @@index([tenantId])
}

model ColdMailbox {
  id                String          @id @default(uuid())
  tenantId          String
  provider          MailboxProvider
  email             String
  fromName          String
  replyToEmail      String?
  status            MailboxStatus   @default(active)
  dailySendLimit    Int             @default(40)
  sendWindowStart   String          @default("08:00")
  sendWindowEnd     String          @default("17:00")
  sendWeekdaysOnly  Boolean         @default(true)
  minDelaySeconds   Int             @default(180)
  maxDelaySeconds   Int             @default(480)
  warmupEnabled     Boolean         @default(false)
  warmupStatus      WarmupStatus    @default(not_started)
  warmupDailyTarget Int             @default(5)
  warmupStartedAt   DateTime?
  sentToday         Int             @default(0)
  totalSent         Int             @default(0)
  bounceRate        Decimal         @db.Decimal(5, 2) @default(0)
  spamRate          Decimal         @db.Decimal(5, 2) @default(0)
  healthScore       Int             @default(0)
  lastSentAt        DateTime?
  signature         String?
  smtpHost          String?
  smtpPort          Int?
  smtpUser          String?
  smtpPassCipher    String?
  oauthTokenCipher  String?
  domainId          String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  tenant            Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  domain            SendingDomain?  @relation(fields: [domainId], references: [id], onDelete: SetNull)
  campaignMailboxes ColdCampaignMailbox[]
  persona           Persona?
  warmupLogs        WarmupLog[]
  sendingLogs       SendingLog[]

  @@unique([tenantId, email])
  @@index([tenantId, status])
}

model ColdProspectList {
  id            String           @id @default(uuid())
  tenantId      String
  name          String
  totalCount    Int              @default(0)
  validCount    Int              @default(0)
  invalidCount  Int              @default(0)
  riskyCount    Int              @default(0)
  createdBy     String
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  tenant        Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  prospects     ColdProspect[]
  campaigns     ColdCampaign[]

  @@index([tenantId, createdAt])
}

model ColdProspect {
  id              String              @id @default(uuid())
  listId          String
  email           String
  firstName       String
  lastName        String
  companyName     String?
  jobTitle        String?
  customVar1      String?
  customVar2      String?
  customVar3      String?
  customVar4      String?
  customVar5      String?
  validationStatus ProspectValidation @default(pending)
  createdAt       DateTime            @default(now())
  list            ColdProspectList    @relation(fields: [listId], references: [id], onDelete: Cascade)
  sequenceStates  ColdSequenceState[]

  @@unique([listId, email])
  @@index([listId, validationStatus])
}

model ColdCampaign {
  id                String               @id @default(uuid())
  tenantId          String
  name              String
  goal              String?
  status            ColdCampaignStatus   @default(draft)
  listId            String?
  stopOnReply       Boolean              @default(true)
  stopOnUnsubscribe Boolean              @default(true)
  trackOpens        Boolean              @default(false)
  trackClicks       Boolean              @default(false)
  trackingDomain    String?
  totalProspects    Int                  @default(0)
  sentCount         Int                  @default(0)
  openCount         Int                  @default(0)
  replyCount        Int                  @default(0)
  positiveReplyCount Int                 @default(0)
  bounceCount       Int                  @default(0)
  unsubCount        Int                  @default(0)
  scheduledAt       DateTime?
  createdBy         String
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  tenant            Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  prospectList      ColdProspectList?    @relation(fields: [listId], references: [id], onDelete: SetNull)
  steps             ColdSequenceStep[]
  mailboxes         ColdCampaignMailbox[]
  sequenceStates    ColdSequenceState[]
