generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  superadmin
  client
}

enum TenantStatus {
  onboarding
  active
  trial
  payment_failed
  suspended
  cancelled
}

enum PlanKey {
  starter
  growth
  business
  enterprise
}

enum ContactStatus {
  lead
  prospect
  customer
  churned
}

enum ContactSource {
  manual
  import
  campaign
  api
}

enum DealStatus {
  open
  won
  lost
}

enum CampaignStatus {
  draft
  scheduled
  sending
  sent
  partial_failed
  cancelled
}

enum EmailEventType {
  delivered
  open
  click
  bounce
  unsubscribe
}

// ── Cold Email Enums ──

enum MailboxProvider {
  gmail
  outlook
  custom_smtp
}

enum WarmupStatus {
  not_started
  warming
  ready
  paused
}

enum MailboxStatus {
  active
  paused
  error
  disconnected
}

enum ProspectValidation {
  valid
  risky
  invalid
  pending
}

enum ColdCampaignStatus {
  draft
  active
  paused
  completed
  error
}

enum ColdProspectStatus {
  queued
  active
  replied
  interested
  not_interested
  unsubscribed
  bounced
  completed
}

enum DnsRecordStatus {
  verified
  not_set
  error
}

enum TenantMemberRole {
  owner
  admin
  sales
  marketer
  viewer
}

enum InviteStatus {
  pending
  accepted
  revoked
  expired
}

enum JobStatus {
  queued
  running
  completed
  failed
  cancelled
}

enum ProviderLogStatus {
  success
  failed
  pending
}

enum NotificationType {
  campaign_completed
  reply_received
  failed_send
  domain_unhealthy
  dns_failure
  mailbox_warmup_paused
  payment_failure
  invite_accepted
  provider_sync_failure
  system
}

enum SuppressionSource {
  manual
  unsubscribe
  bounce
  complaint
  import
}

enum BillingSubscriptionStatus {
  trialing
  active
  past_due
  canceled
  incomplete
  unpaid
}

enum ProvisioningStatus {
  pending
  succeeded
  failed
  rolled_back
}

enum CallSessionStatus {
  uploaded
  transcribing
  transcribed
  summarized
  failed
}

model User {
  id            String         @id @default(uuid())
  name          String
  email         String         @unique
  passwordHash  String
  role          UserRole
  initials      String
  tenantId      String?
  tenantName    String?
  twoFactorEnabled Boolean @default(false)
  twoFactorSecretCipher String?
  backupCodes      String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  memberships   TenantUser[]
  invitesSent   TenantInvite[] @relation("InviteSender")
  refreshTokens RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  sessions      Session[]
  notifications Notification[]
  notificationPreferences NotificationPreference[]
}

model Tenant {
  id              String              @id @default(uuid())
  companyName     String
  contactName     String
  email           String
  phone           String?
  industry        String?
  plan            PlanKey
  status          TenantStatus
  seats           Int
  mrr             Decimal             @db.Decimal(10, 2)
  customPriceEnabled Boolean           @default(false)
  customMrr       Decimal?            @db.Decimal(10, 2)
  discountType    String              @default("none")
  discountValue   Decimal             @default(0) @db.Decimal(10, 2)
  discountReason  String?
  discountExpiresAt DateTime?
  trialEndsAt     DateTime?
  notes           String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  users           TenantUser[]
  enabledServices TenantService[]
  integrations    TenantIntegration[]
  contacts        Contact[]
  companies       Company[]
  deals           Deal[]
  activities      Activity[]
  pipelineStages  PipelineStage[]
  tags            Tag[]
  emailTemplates  EmailTemplate[]
  emailCampaigns  EmailCampaign[]
  aiSessions      AiSession[]
  // Cold Email relations
  coldMailboxes          ColdMailbox[]
  coldProspectLists      ColdProspectList[]
  coldCampaigns          ColdCampaign[]
  sendingDomains         SendingDomain[]
  personas               Persona[]
  emailProviderCredentials EmailProviderCredential[]
  billingSubscriptions BillingSubscription[]
  invoices             Invoice[]
  paymentMethods       PaymentMethodRef[]
  usageRecords         UsageRecord[]
  invites              TenantInvite[]
  jobLogs              JobLog[]
  providerLogs         ProviderLog[]
  notifications        Notification[]
  notificationPreferences NotificationPreference[]
  suppressionEntries   SuppressionEntry[]
  trackingEvents       TrackingEvent[]
  providerExternalAccounts ProviderExternalAccount[]
  mailboxProvisioningLogs  MailboxProvisioningLog[]
  dnsProvisioningLogs      DnsProvisioningLog[]
  callSessions         CallSession[]
  callRecordings       CallRecording[]
  callTranscripts      CallTranscript[]
  callInsights         CallInsight[]
  onboardingItems      OnboardingItem[]
  proposals            Proposal[]
  proposalTemplates    ProposalTemplate[]
  brandSetting         ClientBrandSetting?
  servicePricing       ClientServicePricing[]
  financeInvoices      FinanceInvoice[]
  financePayments      FinancePayment[]
  financeCosts         FinanceCost[]
  financeSubscriptions FinanceSubscription[]
  financeRefunds       FinanceRefund[]
  financeTaxConfigs    FinanceTaxConfig[]
  financeSettings      FinanceSetting?
  financeSequences     FinanceSequence[]
}

model TenantUser {
  id        String   @id @default(uuid())
  tenantId  String
  userId    String
  role      TenantMemberRole @default(viewer)
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([userId])
}

model TenantService {
  id        String   @id @default(uuid())
  tenantId  String
  key       String
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, key])
}

model ServiceCatalog {
  key          String   @id
  label        String
  description  String
  icon         String
  monthlyPrice Decimal  @default(0) @db.Decimal(10, 2)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  plans        PlanCatalogService[]
}

model PlanCatalog {
  key          PlanKey  @id
  label        String
  price        Decimal  @db.Decimal(10, 2)
  billingCycle String   @default("monthly")
  color        String
  bgColor      String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  services     PlanCatalogService[]
}

model PlanCatalogService {
  id         String         @id @default(uuid())
  planKey    PlanKey
  serviceKey String
  plan       PlanCatalog    @relation(fields: [planKey], references: [key], onDelete: Cascade)
  service    ServiceCatalog @relation(fields: [serviceKey], references: [key], onDelete: Cascade)

  @@unique([planKey, serviceKey])
  @@index([serviceKey])
}

model TenantIntegration {
  id           String   @id @default(uuid())
  tenantId     String
  platformKey  String
  customName   String?
  apiKeyCipher String
  monthlyPrice Decimal  @db.Decimal(10, 2)
  isActive     Boolean  @default(true)
  notes        String?
  addedAt      DateTime @default(now())
  updatedAt    DateTime @updatedAt
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  createdAt DateTime @default(now())
  expiresAt DateTime
  revokedAt DateTime?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String   @unique
  createdAt DateTime @default(now())
  expiresAt DateTime
  revokedAt DateTime?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String   @unique
  createdAt DateTime @default(now())
  expiresAt DateTime
  usedAt    DateTime?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AuditLog {
  id          String   @id @default(uuid())
  actorUserId String?
  tenantId    String?
  event       String
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([actorUserId])
  @@index([tenantId])
  @@index([createdAt])
}

model Contact {
  id             String        @id @default(uuid())
  tenantId       String
  firstName      String
  lastName       String
  email          String
  phone          String?
  jobTitle       String?
  companyId      String?
  assignedTo     String?
  status         ContactStatus @default(lead)
  source         ContactSource @default(manual)
  tags           String[]      @default([])
  marketingConsent Boolean     @default(false)
  marketingConsentSource String?
  marketingConsentCapturedAt DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  lastActivityAt DateTime      @default(now())
  tenant         Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  company        Company?      @relation(fields: [companyId], references: [id], onDelete: SetNull)
  activities     Activity[]

  @@unique([tenantId, email])
  @@index([tenantId, status])
  @@index([tenantId, companyId])
}

model Company {
  id         String     @id @default(uuid())
  tenantId   String
  name       String
  domain     String?
  industry   String?
  size       String?
  website    String?
  phone      String?
  assignedTo String?
  tags       String[]   @default([])
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contacts   Contact[]
  deals      Deal[]
  activities Activity[]

  @@index([tenantId, name])
}

model Deal {
  id                String     @id @default(uuid())
  tenantId          String
  title             String
  value             Decimal    @db.Decimal(12, 2)
  currency          String     @default("USD")
  stage             String
  companyId         String?
  assignedTo        String
  status            DealStatus @default(open)
  probability       Int
  expectedCloseDate DateTime?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  tenant            Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  company           Company?   @relation(fields: [companyId], references: [id], onDelete: SetNull)
  activities        Activity[]

  @@index([tenantId, status])
  @@index([tenantId, companyId])
  @@index([tenantId, stage])
}

model PipelineStage {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  order     Int      @default(0)
  color     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, name])
  @@index([tenantId, order])
}

model Tag {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  color     String?
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, name])
  @@index([tenantId])
}

model Activity {
  id        String   @id @default(uuid())
  tenantId  String
  type      String
  subject   String
  body      String?
  contactId String?
  companyId String?
  dealId    String?
  createdBy String
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
  company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  deal      Deal?    @relation(fields: [dealId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([tenantId, contactId])
  @@index([tenantId, companyId])
  @@index([tenantId, dealId])
}

model EmailTemplate {
  id          String   @id @default(uuid())
  tenantId    String
  name        String
  subject     String
  body        String
  contentBlocks Json?
  category    String?
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  campaigns   EmailCampaign[]

  @@index([tenantId, createdAt])
}

model EmailCampaign {
  id              String           @id @default(uuid())
  tenantId        String
  templateId      String?
  name            String
  subject         String
  previewText     String?
  fromName        String
  fromEmail       String
  replyToEmail    String?
  body            String?
  bodyPlainText   String?
  contentBlocks   Json?
  abTestEnabled   Boolean          @default(false)
  abVariants      Json?
  selectedVariant String?
  status          CampaignStatus   @default(draft)
  scheduledAt     DateTime?
  scheduledTz     String?
  sentAt          DateTime?
  cancelledAt     DateTime?
  completedAt     DateTime?
  lastError       String?
  sendJobId       String?
  recipientFilter Json?
  totalRecipients Int              @default(0)
  openCount       Int              @default(0)
  clickCount      Int              @default(0)
  bounceCount     Int              @default(0)
  unsubCount      Int              @default(0)
  dailySendLimit  Int?
  throttlePerHour Int?
  trackOpens      Boolean          @default(true)
  trackClicks     Boolean          @default(true)
  utmSource       String?
  utmMedium       String?
  utmCampaign     String?
  gdprConsent     Boolean          @default(false)
  doubleOptIn     Boolean          @default(false)
  companyAddress  String?
  createdBy       String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  template        EmailTemplate?   @relation(fields: [templateId], references: [id], onDelete: SetNull)
  recipients      CampaignRecipient[]
  events          EmailEvent[]

  @@index([tenantId, status])
  @@index([tenantId, createdAt])
}

model CampaignRecipient {
  id                String        @id @default(uuid())
  campaignId        String
  contactId         String?
  email             String
  firstName         String?
  lastName          String?
  status            String        @default("queued")
  attempts          Int           @default(0)
  providerRequestId String?
  sentAt            DateTime?
  failedAt          DateTime?
  openedAt          DateTime?
  clickedAt         DateTime?
  bouncedAt         DateTime?
  unsubscribedAt    DateTime?
  lastError         String?
  campaign          EmailCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([campaignId, status])
}

model EmailEvent {
  id          String         @id @default(uuid())
  campaignId  String
  recipientId String?
  type        EmailEventType
  url         String?
  providerId  String?
  eventKey    String?
  occurredAt  DateTime       @default(now())
  campaign    EmailCampaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId, type])
  @@unique([providerId])
  @@unique([eventKey])
}

model BillingSubscription {
  id                   String                    @id @default(uuid())
  tenantId             String
  stripeCustomerId     String?
  stripeSubscriptionId String?                   @unique
  plan                 PlanKey
  status               BillingSubscriptionStatus @default(incomplete)
  seats                Int                       @default(1)
  trialEndsAt          DateTime?
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean                   @default(false)
  cancelledAt          DateTime?
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt
  tenant               Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
}

model Invoice {
  id              String   @id @default(uuid())
  tenantId        String
  stripeInvoiceId String?  @unique
  number          String?
  status          String
  amountDue       Decimal  @db.Decimal(10, 2)
  amountPaid      Decimal  @db.Decimal(10, 2) @default(0)
  currency        String   @default("usd")
  hostedUrl       String?
  pdfUrl          String?
  dueDate         DateTime?
  paidAt          DateTime?
  createdAt       DateTime @default(now())
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
}

model PaymentMethodRef {
  id                    String   @id @default(uuid())
  tenantId              String
  stripePaymentMethodId String?  @unique
  brand                 String?
  last4                 String?
  expMonth              Int?
  expYear               Int?
  isDefault             Boolean  @default(false)
  createdAt             DateTime @default(now())
  tenant                Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model UsageRecord {
  id        String   @id @default(uuid())
  tenantId  String
  service   String
  metric    String
  quantity  Int      @default(0)
  unitCost  Decimal? @db.Decimal(12, 6)
  period    String
  metadata  Json?
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, service, period])
}

model Proposal {
  id                  String   @id @default(uuid())
  tenantId            String?
  scope               String   @default("client")
  proposalNumber      String?  @unique
  createdByType       String   @default("client")
  recipientType       String   @default("customer")
  title               String
  recipientName       String
  recipientEmail      String?
  companyName         String?
  contactId           String?
  companyId           String?
  dealId              String?
  status              String   @default("draft")
  billingCycle        String   @default("monthly")
  contractDuration    String?
  paymentTerms        String?
  setupFee            Decimal  @default(0) @db.Decimal(12, 2)
  subtotal            Decimal  @default(0) @db.Decimal(12, 2)
  discountType        String   @default("none")
  discountValue       Decimal  @default(0) @db.Decimal(12, 2)
  discountAmount      Decimal  @default(0) @db.Decimal(12, 2)
  total               Decimal  @default(0) @db.Decimal(12, 2)
  mccCostAmount       Decimal  @default(0) @db.Decimal(12, 2)
  creatorProfitAmount Decimal  @default(0) @db.Decimal(12, 2)
  validUntil          DateTime?
  customIntroMessage  String?
  templateId          String   @default("modern")
  brandingSnapshot    Json?
  trackingToken       String   @unique @default(uuid())
  pdfUrl              String?
  sentAt              DateTime?
  viewedAt            DateTime?
  acceptedAt          DateTime?
  rejectedAt          DateTime?
  signatureData       Json?
  notes               String?
  createdBy           String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  tenant              Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lineItems           ProposalLineItem[]
  services            ProposalService[]
  sections            ProposalSection[]
  activities          ProposalActivity[]

  @@index([tenantId, status])
  @@index([scope, createdAt])
  @@index([trackingToken])
}

model ProposalLineItem {
  id          String   @id @default(uuid())
  proposalId  String
  name        String
  description String?
  quantity    Int      @default(1)
  unitPrice   Decimal  @default(0) @db.Decimal(12, 2)
  total       Decimal  @default(0) @db.Decimal(12, 2)
  proposal    Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  @@index([proposalId])
}

model ProposalService {
  id                 String   @id @default(uuid())
  proposalId         String
  serviceType        String
  planName           String
  listPrice          Decimal  @db.Decimal(12, 2)
  discountPercentage Decimal  @default(0) @db.Decimal(5, 2)
  finalPrice         Decimal  @db.Decimal(12, 2)
  mccBaseCost        Decimal  @default(0) @db.Decimal(12, 2)
  creatorMargin      Decimal  @default(0) @db.Decimal(12, 2)
  features           Json     @default("[]")
  customDescription  String?
  sortOrder          Int      @default(0)
  createdAt          DateTime @default(now())
  proposal           Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  @@index([proposalId])
}

model ProposalSection {
  id           String   @id @default(uuid())
  proposalId   String
  sectionKey   String
  sectionTitle String
  content      Json?
  isEnabled    Boolean  @default(true)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  proposal     Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  @@index([proposalId])
}

model ProposalActivity {
  id         String   @id @default(uuid())
  proposalId String
  eventType  String
  actorType  String
  actorId    String?
  metadata   Json?
  createdAt  DateTime @default(now())
  proposal   Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  @@index([proposalId, createdAt])
}

model ProposalTemplate {
  id              String   @id @default(uuid())
  tenantId        String?
  scope           String   @default("client")
  name            String
  description     String?
  style           String   @default("modern")
  aboutUsContent  String?
  termsItems      Json     @default("[]")
  timelineSteps   Json     @default("[]")
  isDefault       Boolean  @default(false)
  createdBy       String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  tenant          Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, scope])
}

model ClientBrandSetting {
  id             String   @id @default(uuid())
  tenantId       String   @unique
  companyName    String?
  logoUrl        String?
  primaryColor   String   @default("#1a56db")
  accentColor    String   @default("#7c3aed")
  fontFamily     String   @default("Inter")
  contactEmail   String?
  contactPhone   String?
  websiteUrl     String?
  address        String?
  aboutUsText    String?
  proposalPrefix String?
  updatedAt      DateTime @updatedAt
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model ClientServicePricing {
  id               String   @id @default(uuid())
  tenantId         String
  serviceType      String
  planName         String
  mccCost          Decimal  @db.Decimal(12, 2)
  sellingPrice     Decimal  @db.Decimal(12, 2)
  marginAmount     Decimal  @db.Decimal(12, 2)
  marginPercentage Decimal  @db.Decimal(5, 2)
  planFeatures     Json     @default("[]")
  isActive         Boolean  @default(true)
  updatedAt        DateTime @updatedAt
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, serviceType, planName])
  @@index([tenantId])
}

model FinanceInvoice {
  id                     String   @id @default(uuid())
  tenantId               String?
  scope                  String   @default("client")
  number                 String
  invoiceType            String   @default("one_time")
  createdByType          String   @default("client")
  recipientType          String   @default("customer")
  recipientId            String?
  recipientName          String
  recipientEmail         String?
  recipientCompany       String?
  contactId              String?
  companyId              String?
  proposalId             String?
  subscriptionId         String?
  status                 String   @default("draft")
  billingPeriodStart     DateTime?
  billingPeriodEnd       DateTime?
  issueDate              DateTime @default(now())
  dueDate                DateTime?
  subtotal               Decimal  @default(0) @db.Decimal(12, 2)
  discountType           String   @default("none")
  discountValue          Decimal  @default(0) @db.Decimal(12, 2)
  discountAmount         Decimal  @default(0) @db.Decimal(12, 2)
  taxRate                Decimal  @default(0) @db.Decimal(8, 4)
  taxAmount              Decimal  @default(0) @db.Decimal(12, 2)
  total                  Decimal  @default(0) @db.Decimal(12, 2)
  amountPaid             Decimal  @default(0) @db.Decimal(12, 2)
  balanceDue             Decimal  @default(0) @db.Decimal(12, 2)
  currency               String   @default("USD")
  paymentTerms           String?
  notes                  String?
  paymentInstructions    String?
  templateId             String   @default("modern")
  internalNotes          String?
  brandingSnapshot       Json?
  pdfUrl                 String?
  pdfGeneratedAt         DateTime?
  publicToken            String   @unique @default(uuid())
  sentAt                 DateTime?
