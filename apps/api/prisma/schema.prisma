model SendingDomain {
  id                   String          @id @default(uuid())
  tenantId             String
  domain               String
  spfStatus            DnsRecordStatus @default(not_set)
  dkimStatus           DnsRecordStatus @default(not_set)
  dmarcStatus          DnsRecordStatus @default(not_set)
  mxStatus             DnsRecordStatus @default(not_set)
  dkimSelector         String?
  dkimType             String?
  dkimHost             String?
  dkimValue            String?
  trackingDomain       String?
  trackingCnameValue   String?
