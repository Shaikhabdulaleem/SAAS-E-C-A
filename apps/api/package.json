{
  "name": "@nexushq/api",
  "version": "0.0.1",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "format": "prettier --write \"src/**/*.ts\" \"prisma/**/*.ts\"",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "tsx prisma/seed.ts",
    "start": "node dist/src/main.js",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/src/main.js",
    "worker": "node dist/src/worker.js",
    "test": "jest --config jest.config.cjs"
  },
  "dependencies": {
    "@nestjs/common": "11.1.27",
    "@nestjs/config": "3.3.0",
    "@nestjs/core": "10.4.15",
    "@nestjs/platform-express": "10.4.15",
    "@prisma/client": "6.1.0",
    "bullmq": "^5.79.0",
    "chokidar": "^3.6.0",
    "googleapis": "^173.0.0",
    "ioredis": "^5.11.1",
    "picomatch": "^2.3.1",
    "puppeteer": "^25.1.0",
    "readdirp": "^3.6.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "10.4.8",
    "@nestjs/schematics": "10.2.3",
    "@nestjs/testing": "10.4.15",
    "@types/express": "5.0.0",
    "@types/jest": "29.5.14",
    "@types/multer": "^2.1.0",
    "@types/node": "22.10.2",
    "jest": "29.7.0",
    "prettier": "3.4.2",
    "prisma": "6.1.0",
    "source-map-support": "0.5.21",
    "supertest": "7.0.0",
    "ts-jest": "29.2.5",
    "ts-loader": "9.5.1",
    "ts-node": "10.9.2",
    "tsx": "4.19.2",
    "typescript": "^5.7.2"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
